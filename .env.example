# Public HTTPS origin used by Claude / ChatGPT to connect to the MCP endpoint
# and by the widget iframe to stream /stream/* /cover/* /lrc/*.
# Required in production (NODE_ENV=production).
PUBLIC_BASE_URL=https://music.example.com
PORT=3000

# Streamable HTTP MCP route. /mcp is always kept as an alias for local smoke tests.
MCP_HTTP_PATH=/mcp/music

# CORS allowlist (comma separated). Defaults to the PUBLIC_BASE_URL origin.
ALLOWED_ORIGINS=https://music.example.com

# Meting-compatible API endpoint (https://github.com/metowolf/Meting style).
METING_API_BASE=https://api.qijieya.cn/meting/

# Default music platform: netease | tencent | kugou | kuwo | baidu
DEFAULT_MUSIC_SERVER=netease

# Optional OAuth password gate for remote connectors.
# Leave empty to disable auth; set a password to enable Authorization Code auth.
MCP_AUTH_PASSWORD=
# Optional display name on the OAuth password page.
MCP_AUTH_SERVICE_NAME=music-mcp
